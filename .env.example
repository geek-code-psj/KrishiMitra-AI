# KrishiMitra AI — Environment Variables
# Copy this file to .env and fill in the values

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=KrishiMitra AI
VERSION=1.0.0
DEBUG=true
ENV=development

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Security (REQUIRED — generate with: openssl rand -hex 32) ────────────────
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — zero setup, DPDP Act compliant edge DB)
DATABASE_URL=sqlite+aiosqlite:///./krishimitra.db

# PostgreSQL (production — uncomment and fill)
# DATABASE_URL=postgresql+asyncpg://krishimitra:password@localhost:5432/krishimitra

# ─── Redis (optional — app runs without it, predictions are not cached) ────────
REDIS_URL=redis://localhost:6379/0
# REDIS_URL=   # leave empty to disable cache entirely

# ─── AIKosh API (get from https://aikosh.indiaai.gov.in) ──────────────────────
AIKOSH_API_KEY=
AIKOSH_BASE_URL=https://aikosha.indiaai.gov.in/api/v1

# ─── AI4Bharat / Sarvam Voice Models ──────────────────────────────────────────
AI4BHARAT_ASR_URL=
AI4BHARAT_TTS_URL=
SARVAM_API_KEY=

# ─── Ollama (local LLM — runs on localhost via ollama serve) ──────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder

# ─── External APIs ────────────────────────────────────────────────────────────
IMD_API_KEY=
AGMARKNET_API_KEY=

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
# S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── ML Models ────────────────────────────────────────────────────────────────
MODEL_CACHE_DIR=./models/cache
DEFAULT_MODEL_DEVICE=cpu

# ─── Voice ────────────────────────────────────────────────────────────────────
VOICE_MAX_DURATION=60
DEFAULT_LANGUAGE=hi

# ─── Monitoring ───────────────────────────────────────────────────────────────
# SENTRY_DSN=

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_HOSTS=["http://localhost:3000","http://127.0.0.1:3000"]

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_VOICE_AI=true
ENABLE_PREDICTIONS=true
ENABLE_GEOSPATIAL=true
ENABLE_OFFLINE_SYNC=true
